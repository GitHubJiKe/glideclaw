{
  "name": "glideclaw",
  "version": "0.1.4",
  "description": "Local-first rolling-context AI CLI built with Bun + SQLite.",
  "bin": {
    "glideclaw": "./dist/index.js"
  },
  "files": [
    "dist/**",
    "src/ui/**",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "license": "MIT",
  "keywords": [
    "cli",
    "bun",
    "sqlite",
    "openai",
    "local-first"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "bun build ./src/bin.ts --target=bun --outfile ./dist/index.js && bun run ./scripts/add-shebang.ts ./dist/index.js",
    "web": "bun run src/server.ts",
    "test": "bun test",
    "prepublishOnly": "bun run build && bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "chalk": "^5.6.2",
    "openai": "^6.27.0",
    "zod": "^4.3.6"
  }
}
